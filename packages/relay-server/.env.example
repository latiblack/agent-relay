# Agent Relay - Environment Configuration
# Copy to .env and fill in your values

UNICITY_NETWORK=testnet
DATA_DIR=./data
RELAY_PORT=3104
WSS_PORT=3105

# Quest Agent Mnemonics (generate with Sphere SDK)
# These are the permanent identities for each quest agent
VERIFICATION_MNEMONIC=
PUZZLE_MNEMONIC=
LORE_MNEMONIC=
TREASURY_MNEMONIC=

# SphereQuests popup bridge configuration
SPHEREQUESTS_URL=https://quest.unicity.network
SPHEREQUESTS_API_URL=https://quest-api.unicity.network
XP_REQUIREMENT=100

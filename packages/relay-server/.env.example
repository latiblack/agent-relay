# Agent Relay - Environment Configuration
# Copy to .env and fill in values

# Network
UNICITY_NETWORK=testnet
DATA_DIR=./data
RELAY_PORT=3104
WSS_PORT=3105

# Quest Agent Mnemonics (generate fresh for production!)
VERIFICATION_MNEMONIC=
PUZZLE_MNEMONIC=
LORE_MNEMONIC=
TREASURY_MNEMONIC=
IN_APP_MNEMONIC=

# Supabase (required for passport persistence)
# Create project at https://supabase.com → get these from Project Settings > API
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# SphereQuests (optional, for XP verification)
SPHEREQUESTS_URL=https://quest.unicity.network
SPHEREQUESTS_API_URL=https://quest-api.unicity.network
XP_REQUIREMENT=100
